node_modules
.pnpm-store/
**/.pnpm-store/
.pnp
.pnp.js

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.claude

# Testing
coverage
apps/web/test-results/

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
out/
build
dist
coverage
next-env.d.ts
*.tsbuildinfo
*.db
*.db-*
*.sqlite
*.sqlite3


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# Licensed fonts (self-hosted; license must be verified before committing)
apps/*/public/fonts/**/*.woff
apps/*/public/fonts/**/*.woff2
apps/*/public/fonts/**/*.ttf
apps/*/public/fonts/**/*.otf
