{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_URL",
    "LOGOS_CONTENT_ROOT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "PAYLOAD_SECRET",
        "DATABASE_URL",
        "DATABASE_AUTH_TOKEN",
        "PAYLOAD_DB_SCHEMA",
        "PAYLOAD_DB_PUSH",
        "NEXT_PUBLIC_SERVER_URL",
        "NEXT_PUBLIC_WEB_URL",
        "CIVICRM_BASE_URL",
        "CIVICRM_API_KEY",
        "ACTIVE_VIEW",
        "KEYCLOAK_USER_EMAIL_HEADER",
        "DEV_USER_EMAIL_MOCK"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:static": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:perf": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "generate-types": {
      "cache": false,
      "outputs": ["packages/types/src/payload.ts"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
